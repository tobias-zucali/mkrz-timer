FROM node:22-alpine AS build
WORKDIR /app
ARG NEXT_PUBLIC_REMOTE_WS_URL=wss://ws.timer.mkrz.at/ws
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY src ./src
COPY public ./public
COPY scripts ./scripts
COPY next.config.ts tsconfig.json postcss.config.mjs eslint.config.mjs ./
RUN corepack enable && pnpm install --frozen-lockfile
RUN NEXT_PUBLIC_REMOTE_WS_URL=$NEXT_PUBLIC_REMOTE_WS_URL pnpm build

FROM node:22-alpine
WORKDIR /app
COPY --from=build /app/out ./out
COPY scripts/serve-static.mjs ./serve-static.mjs
EXPOSE 3000
CMD ["node", "serve-static.mjs", "--root", "out", "--host", "0.0.0.0", "--port", "3000"]
