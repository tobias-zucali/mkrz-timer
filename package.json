{
  "name": "mkrz-timer",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/runtime-lane.mjs start --lane=dev",
    "dev:test": "node scripts/runtime-lane.mjs start --lane=test",
    "dev:relay": "node --no-warnings=ExperimentalWarning --experimental-strip-types --experimental-default-type=module src/server/relay/index.ts",
    "start": "next start",
    "build": "next build",
    "build:full": "run-s test:full build",
    "build:docker": "run-s build:full build:docker:images",
    "build:docker:images": "docker compose build",
    "lint": "run-s lint:eslint lint:typecheck",
    "lint:fix": "run-s lint:eslint:fix lint:typecheck",
    "lint:eslint": "eslint",
    "lint:eslint:fix": "eslint --fix",
    "lint:typecheck": "tsc --noEmit",
    "format": "prettier --check --ignore-path .gitignore --ignore-path .prettierignore .",
    "format:fix": "prettier --write --ignore-path .gitignore --ignore-path .prettierignore .",
    "test": "run-s lint test:unit test:components test:e2e:smoke",
    "test:ci": "run-s test:unit test:components test:e2e:ci",
    "test:full": "run-s lint test:unit test:components test:e2e:full",
    "test:unit": "node --no-warnings=ExperimentalWarning --experimental-strip-types --experimental-default-type=module --test src/**/*.test.ts",
    "test:components": "vitest run src/components/**/*.test.tsx",
    "test:e2e:smoke": "pnpm test:e2e:local:smoke",
    "test:e2e:ci": "run-s test:e2e:local:ci test:e2e:remote:ci",
    "test:e2e:full": "run-s test:e2e:local test:e2e:remote",
    "test:e2e:run": "node scripts/runtime-lane.mjs test --lane=test",
    "test:e2e:run:remote": "node scripts/runtime-lane.mjs test --lane=test --remote",
    "test:e2e:local": "pnpm test:e2e:run",
    "test:e2e:local:smoke": "pnpm test:e2e:run -- --grep @smoke",
    "test:e2e:local:ci": "pnpm test:e2e:run -- --grep-invert @visual",
    "test:e2e:local:visual": "pnpm test:e2e:run -- --grep @visual --headed --workers=1",
    "test:e2e:remote": "pnpm test:e2e:run:remote",
    "test:e2e:remote:ci": "pnpm test:e2e:run:remote -- --grep-invert @visual",
    "test:e2e:remote:visual": "pnpm test:e2e:run:remote -- --grep @visual --headed --workers=1",
    "test:e2e:pwa": "run-s test:e2e:pwa:clean build test:e2e:pwa:run",
    "test:e2e:pwa:clean": "rimraf test-results playwright-report",
    "test:e2e:pwa:run": "playwright test tests/e2e/timer/pwa.spec.ts --config=playwright.pwa.config.ts",
    "test:e2e:ui": "pnpm test:e2e:run -- --ui",
    "test:e2e:debug": "pnpm test:e2e:run -- --debug --workers=1",
    "test:e2e:visual": "run-s test:e2e:local:visual test:e2e:remote:visual",
    "test:e2e:report": "node scripts/runtime-lane.mjs report",
    "scope": "node scripts/agent-scope.mjs",
    "scope:audit": "node scripts/agent-scope.mjs --audit"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "next": "16.2.4",
    "next-intl": "^4.12.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "jsdom": "^27.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.0.8",
    "ws": "^8.18.3"
  },
  "packageManager": "pnpm@8.11.0+sha1.01bf39424f1008f29012bbae851d2acb8a20a0d0"
}
