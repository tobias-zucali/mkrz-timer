{
  "name": "mkrz-timer",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/dev-stack.mjs",
    "dev:test": "NEXT_DIST_DIR=.next-e2e NEXT_PUBLIC_REMOTE_WS_URL=ws://127.0.0.1:9100/ws next dev -H 127.0.0.1 -p 3100",
    "dev:relay": "node --no-warnings=ExperimentalWarning --experimental-strip-types --experimental-default-type=module src/server/relay/index.ts",
    "start": "next start",
    "build": "next build",
    "build:full": "run-s test:full build",
    "build:docker": "run-s build:full build:docker:images",
    "build:docker:images": "docker compose build",
    "lint": "run-s lint:eslint lint:typecheck",
    "lint:fix": "run-s lint:eslint:fix lint:typecheck",
    "lint:eslint": "eslint",
    "lint:eslint:fix": "eslint --fix",
    "lint:typecheck": "tsc --noEmit",
    "format": "prettier --check --ignore-path .gitignore --ignore-path .prettierignore .",
    "format:fix": "prettier --write --ignore-path .gitignore --ignore-path .prettierignore .",
    "test": "run-s lint test:unit test:components test:e2e:smoke",
    "test:ci": "run-s lint test:unit test:components test:e2e:ci",
    "test:full": "run-s lint test:unit test:components test:e2e:full",
    "test:unit": "node --no-warnings=ExperimentalWarning --experimental-strip-types --experimental-default-type=module --test src/i18n/**/*.test.ts src/shared/**/*.test.ts src/utils/**/*.test.ts src/server/**/*.test.ts",
    "test:components": "vitest run src/components/**/*.test.tsx",
    "test:e2e:smoke": "rimraf test-results playwright-report && playwright test --grep @smoke",
    "test:e2e:ci": "rimraf test-results playwright-report && playwright test --grep-invert @visual",
    "test:e2e:full": "rimraf test-results playwright-report && playwright test",
    "test:e2e:pwa": "run-s test:e2e:pwa:clean build test:e2e:pwa:run",
    "test:e2e:pwa:clean": "rimraf test-results playwright-report",
    "test:e2e:pwa:run": "playwright test tests/e2e/pwa.spec.ts --config=playwright.pwa.config.ts",
    "test:e2e:ui": "rimraf test-results playwright-report && playwright test --ui",
    "test:e2e:debug": "rimraf test-results playwright-report && playwright test --debug --workers=1",
    "test:e2e:visual": "rimraf test-results playwright-report && playwright test --grep @visual --headed --workers=1",
    "test:e2e:report": "playwright show-report",
    "agent:serve:manual": "node scripts/agent-lane.mjs serve app --role=manual",
    "agent:serve:test": "node scripts/agent-lane.mjs serve app --role=test",
    "agent:serve:relay": "node scripts/agent-lane.mjs serve relay",
    "agent:test": "rimraf test-results-agent playwright-report-agent && node scripts/agent-lane.mjs test --grep @smoke",
    "agent:test:attach": "rimraf test-results-agent playwright-report-agent && node scripts/agent-lane.mjs test --attach --grep @smoke",
    "agent:test:full": "rimraf test-results-agent playwright-report-agent && node scripts/agent-lane.mjs test",
    "agent:test:debug": "rimraf test-results-agent playwright-report-agent && node scripts/agent-lane.mjs test --attach --debug --workers=1",
    "agent:status": "node scripts/agent-lane.mjs status",
    "agent:stop": "node scripts/agent-lane.mjs stop"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "next": "16.2.4",
    "next-intl": "^4.12.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "jsdom": "^27.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.0.8",
    "ws": "^8.18.3"
  },
  "packageManager": "pnpm@8.11.0+sha1.01bf39424f1008f29012bbae851d2acb8a20a0d0"
}
