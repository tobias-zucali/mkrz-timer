FROM node:22-alpine
WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY src ./src
COPY scripts ./scripts
RUN corepack enable && pnpm install --frozen-lockfile
EXPOSE 9100
CMD ["node", "--no-warnings=ExperimentalWarning", "--experimental-strip-types", "--experimental-default-type=module", "src/server/relay/index.ts"]
